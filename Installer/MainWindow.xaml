<Window x:Class="RqaInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Установка Revit Quick Access" Width="600" SizeToContent="Height" MinHeight="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#FFFAFBFC" FontFamily="Segoe UI" FontSize="13" Foreground="#FF2E3136">
    <Window.Resources>
        <SolidColorBrush x:Key="Amber"      Color="#FFC6811E"/>
        <SolidColorBrush x:Key="AmberHover" Color="#FFD8912A"/>
        <SolidColorBrush x:Key="AmberText"  Color="#FFB0731A"/>
        <SolidColorBrush x:Key="BorderMid"  Color="#FFA7ABB0"/>
        <SolidColorBrush x:Key="BorderLight" Color="#FFD3D6DA"/>
        <SolidColorBrush x:Key="LightBg"    Color="#FFF5F6F7"/>
        <SolidColorBrush x:Key="LightHover" Color="#FFE5E8EB"/>
        <SolidColorBrush x:Key="TextDark"   Color="#FF2E3136"/>
        <SolidColorBrush x:Key="TextMuted"  Color="#FF7A7E83"/>

        <ControlTemplate x:Key="AnimBtn" TargetType="ButtonBase">
            <Border x:Name="bd" Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True" RenderTransformOrigin="0.5,0.5">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Background"
                            Value="{Binding Tag, RelativeSource={RelativeSource Mode=TemplatedParent}}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="bd" Property="RenderTransform">
                        <Setter.Value><ScaleTransform ScaleX="0.97" ScaleY="0.97"/></Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="bd" Property="Background" Value="#FFEEEFF1"/>
                    <Setter Property="Foreground" Value="#FFAEB1B5"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="AmberBtn" TargetType="Button">
            <Setter Property="Template" Value="{StaticResource AnimBtn}"/>
            <Setter Property="Background" Value="{StaticResource Amber}"/>
            <Setter Property="Tag" Value="{StaticResource AmberHover}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/><Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="18,10"/><Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="LightBtn" TargetType="Button">
            <Setter Property="Template" Value="{StaticResource AnimBtn}"/>
            <Setter Property="Background" Value="{StaticResource LightBg}"/>
            <Setter Property="Tag" Value="{StaticResource LightHover}"/>
            <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMid}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="18,10"/><Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- hero -->
        <Border Grid.Row="0" BorderBrush="{StaticResource Amber}" BorderThickness="0,0,0,3" Padding="24,20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF2B3440" Offset="0"/>
                    <GradientStop Color="#FF3A4656" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                <TextBlock Text="Revit Quick Access" FontSize="26" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="lblSubtitle" Text="Плагин для Revit 2026 · бинды, быстрые команды, диспетчер"
                           Foreground="#FFC9D3DE" Margin="0,6,0,0" FontSize="13"/>
                <TextBlock x:Name="lblVersion" Text="ВЕРСИЯ 1.0" Foreground="#FFD8A85A" FontFamily="Consolas"
                           FontWeight="SemiBold" FontSize="11" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- body -->
        <StackPanel Grid.Row="1" Margin="24,18,24,18">
            <!-- auto-playing preview slideshow (hidden when no screenshots are embedded) -->
            <Border x:Name="shotPanel" Visibility="Collapsed" Margin="0,0,0,16"
                    BorderBrush="{StaticResource BorderMid}" BorderThickness="1" Background="#FF23282F">
                <Grid>
                    <Image x:Name="imgShot" Height="210" Stretch="Uniform" Margin="1"/>
                    <TextBlock x:Name="lblShot" Foreground="#FFC9D3DE" FontSize="10" Margin="8,0,8,6"
                               HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                </Grid>
            </Border>

            <TextBlock Text="ПАПКА УСТАНОВКИ" Foreground="{StaticResource AmberText}" FontWeight="Bold" FontSize="11" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderMid}" BorderThickness="1" Padding="10,9">
                    <TextBlock x:Name="lblPath" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextDark}"
                               TextTrimming="CharacterEllipsis"/>
                </Border>
                <Button Grid.Column="1" x:Name="btnOpenFolder" Style="{StaticResource LightBtn}" Content="Открыть"
                        Margin="8,0,0,0" Click="BtnOpenFolder_Click"/>
            </Grid>

            <Border BorderBrush="{StaticResource BorderLight}" BorderThickness="1" Background="#FFF6F7F8" Padding="14,12" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="Будет установлено:" FontWeight="Bold" FontSize="12" Foreground="{StaticResource TextDark}" Margin="0,0,0,9"/>
                    <StackPanel>
                        <TextBlock Margin="0,1"><Run Text="›  " Foreground="#FFC6811E" FontWeight="Bold"/><Run Text="RevitQuickAccess.dll — плагин"/></TextBlock>
                        <TextBlock Margin="0,1"><Run Text="›  " Foreground="#FFC6811E" FontWeight="Bold"/><Run Text="RevitQuickAccess.addin — манифест загрузки"/></TextBlock>
                        <TextBlock Margin="0,1"><Run Text="›  " Foreground="#FFC6811E" FontWeight="Bold"/><Run Text="Ярлык деинсталляции в «Установка и удаление программ»"/></TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="revitBar" Background="#FFFBF1DE" BorderBrush="{StaticResource Amber}" BorderThickness="4,1,1,1" Padding="12,9" Margin="0,0,0,14">
                <TextBlock x:Name="lblRevit" TextWrapping="Wrap" Foreground="#FF8A5A12" FontSize="12"/>
            </Border>

            <ProgressBar x:Name="progress" Height="8" Minimum="0" Maximum="100" Value="0"
                         Background="#FFEAEBED" Foreground="{StaticResource Amber}" BorderThickness="0"/>
            <TextBlock x:Name="lblStatus" Margin="0,8,0,0" Foreground="{StaticResource TextMuted}" FontSize="12"/>

            <Border BorderBrush="{StaticResource BorderLight}" BorderThickness="0,1,0,0" Margin="0,14,0,0" Padding="0,14,0,0">
                <DockPanel LastChildFill="False">
                    <Button x:Name="btnInstall" DockPanel.Dock="Left" Style="{StaticResource AmberBtn}" Content="Установить" Click="BtnInstall_Click"/>
                    <Button x:Name="btnRefresh" DockPanel.Dock="Left" Style="{StaticResource LightBtn}" Content="Проверить Revit" Margin="8,0,0,0" Click="BtnRefresh_Click"/>
                    <Button x:Name="btnUninstall" DockPanel.Dock="Left" Style="{StaticResource LightBtn}" Content="Удалить" Margin="8,0,0,0"
                            Click="BtnUninstall_Click" Visibility="Collapsed"/>
                    <Button x:Name="btnClose" DockPanel.Dock="Right" Style="{StaticResource LightBtn}" Content="Закрыть" Click="BtnClose_Click"/>
                </DockPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="RevitQuickAccess.UI.CouplingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Автомуфты" Width="520" Height="560"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        Background="#FFF8F9FA" FontFamily="Segoe UI" FontSize="13" Foreground="#FF2E3136">
    <Window.Resources>
        <SolidColorBrush x:Key="Amber" Color="#FFC6811E"/>
        <SolidColorBrush x:Key="AmberHover" Color="#FFD8912A"/>
        <SolidColorBrush x:Key="LightBg" Color="#FFF5F6F7"/>
        <SolidColorBrush x:Key="LightHover" Color="#FFE5E8EB"/>
        <SolidColorBrush x:Key="BorderMid" Color="#FFA7ABB0"/>
        <SolidColorBrush x:Key="TextMid" Color="#FF696D72"/>

        <ControlTemplate x:Key="AnimBtn" TargetType="ButtonBase">
            <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform><ScaleTransform/></Border.RenderTransform>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="{Binding Tag, RelativeSource={RelativeSource Mode=TemplatedParent}}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard><Storyboard>
                            <DoubleAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="0.94" Duration="0:0:0.07"/>
                            <DoubleAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="0.94" Duration="0:0:0.07"/>
                        </Storyboard></BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard><Storyboard>
                            <DoubleAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.13"/>
                            <DoubleAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.13"/>
                        </Storyboard></BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <Style x:Key="AmberBtn" TargetType="Button">
            <Setter Property="Template" Value="{StaticResource AnimBtn}"/>
            <Setter Property="Background" Value="{StaticResource Amber}"/>
            <Setter Property="Tag" Value="{StaticResource AmberHover}"/>
            <Setter Property="Foreground" Value="White"/><Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="18,8"/><Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="LightBtn" TargetType="Button">
            <Setter Property="Template" Value="{StaticResource AnimBtn}"/>
            <Setter Property="Background" Value="{StaticResource LightBg}"/>
            <Setter Property="Tag" Value="{StaticResource LightHover}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMid}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/><Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- header -->
        <Border Grid.Row="0" Background="#FFECEEF0" BorderBrush="{StaticResource Amber}" BorderThickness="0,0,0,2" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Автомуфты" FontSize="17" FontWeight="Bold"/>
                    <TextBlock x:Name="lblTotal" Foreground="{StaticResource TextMid}" FontSize="12" Margin="0,3,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource LightBtn}" Content="Изменить выбор"
                        VerticalAlignment="Center" Click="Reselect_Click"
                        ToolTip="Закрыть и выбрать трубы заново"/>
            </Grid>
        </Border>

        <!-- per pipe-type blocks -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14">
            <ItemsControl x:Name="icGroups">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource BorderMid}" BorderThickness="1" Background="White"
                                Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="{Binding Header}" FontWeight="Bold" Margin="0,0,0,8"/>

                                <TextBlock Text="{Binding Warning}" Visibility="{Binding WarningVisibility}"
                                           Foreground="#FFB0731A" TextWrapping="Wrap" FontSize="11" Margin="0,0,0,8"/>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Расстояние между муфтами, мм:" VerticalAlignment="Center"
                                               FontSize="11" Foreground="{StaticResource TextMid}" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="1" Text="{Binding StepMm, UpdateSourceTrigger=PropertyChanged}"
                                             BorderBrush="{StaticResource BorderMid}" BorderThickness="1" Padding="6,4"/>
                                </Grid>

                                <TextBlock Text="Тип соединения (муфта):" FontSize="11" Foreground="{StaticResource TextMid}" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding Unions}" SelectedItem="{Binding Selected, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding Preview}" Width="36" Height="36" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="360"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <CheckBox IsChecked="{Binding AssignToType, Mode=TwoWay}" Margin="0,8,0,0" FontSize="11"
                                          Foreground="{StaticResource TextMid}"
                                          Content="назначить это соединение в трассировке типа (навсегда)"
                                          ToolTip="Снято — муфта используется только сейчас, настройки типа не меняются"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- footer -->
        <Border Grid.Row="2" Background="#FFF1F2F4" BorderBrush="#FFD3D6DA" BorderThickness="0,1,0,0" Padding="18,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource LightBtn}" Content="Отмена" Click="Cancel_Click"/>
                <Button Style="{StaticResource AmberBtn}" Content="Применить" Margin="8,0,0,0" Click="Apply_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

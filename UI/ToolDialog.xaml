<Window x:Class="RevitQuickAccess.UI.ToolDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Access" Width="620" Height="600"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        Background="#FFF8F9FA" FontFamily="Segoe UI" FontSize="13" Foreground="#FF2E3136">
    <Window.Resources>
        <SolidColorBrush x:Key="Amber" Color="#FFC6811E"/>
        <SolidColorBrush x:Key="AmberHover" Color="#FFD8912A"/>
        <SolidColorBrush x:Key="LightBg" Color="#FFF5F6F7"/>
        <SolidColorBrush x:Key="LightHover" Color="#FFE5E8EB"/>
        <SolidColorBrush x:Key="BorderMid" Color="#FFA7ABB0"/>
        <SolidColorBrush x:Key="TextMid" Color="#FF696D72"/>

        <ControlTemplate x:Key="AnimBtn" TargetType="ButtonBase">
            <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform><ScaleTransform/></Border.RenderTransform>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="{Binding Tag, RelativeSource={RelativeSource Mode=TemplatedParent}}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard><Storyboard>
                            <DoubleAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="0.94" Duration="0:0:0.07"/>
                            <DoubleAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="0.94" Duration="0:0:0.07"/>
                        </Storyboard></BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard><Storyboard>
                            <DoubleAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.13"/>
                            <DoubleAnimation Storyboard.TargetName="bd" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.13"/>
                        </Storyboard></BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <Style x:Key="AmberBtn" TargetType="Button">
            <Setter Property="Template" Value="{StaticResource AnimBtn}"/>
            <Setter Property="Background" Value="{StaticResource Amber}"/>
            <Setter Property="Tag" Value="{StaticResource AmberHover}"/>
            <Setter Property="Foreground" Value="White"/><Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="18,8"/><Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="LightBtn" TargetType="Button">
            <Setter Property="Template" Value="{StaticResource AnimBtn}"/>
            <Setter Property="Background" Value="{StaticResource LightBg}"/>
            <Setter Property="Tag" Value="{StaticResource LightHover}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderMid}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/><Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- header -->
        <Border Grid.Row="0" Background="#FFECEEF0" BorderBrush="{StaticResource Amber}" BorderThickness="0,0,0,2" Padding="18,14">
            <StackPanel>
                <TextBlock x:Name="lblTitle" FontSize="17" FontWeight="Bold"/>
                <TextBlock x:Name="lblSubtitle" Foreground="{StaticResource TextMid}" FontSize="12"
                           Margin="0,3,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14">
            <StackPanel>
                <!-- dropdowns -->
                <ItemsControl x:Name="icChoices">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="{Binding Label}" FontSize="11" Foreground="{StaticResource TextMid}" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding Items}" SelectedItem="{Binding Selected, Mode=TwoWay}"
                                          ToolTip="{Binding Tip}" Padding="6,4"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- free-text input (only some tools use it) -->
                <StackPanel x:Name="pnlInput" Visibility="Collapsed" Margin="0,0,0,12">
                    <TextBlock x:Name="lblInput" FontSize="11" Foreground="{StaticResource TextMid}" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtInput" BorderBrush="{StaticResource BorderMid}" BorderThickness="1" Padding="6,4"/>
                </StackPanel>

                <!-- checkboxes -->
                <ItemsControl x:Name="icFlags" Margin="0,0,0,12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Content="{Binding Text}"
                                      ToolTip="{Binding Tip}" Margin="0,0,0,6" FontSize="12"
                                      Foreground="{StaticResource TextMid}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- live details of the current selection -->
                <TextBlock Text="Что будет сделано:" FontSize="11" Foreground="{StaticResource TextMid}" Margin="0,0,0,4"/>
                <Border BorderBrush="{StaticResource BorderMid}" BorderThickness="1" Background="White" Padding="10">
                    <TextBlock x:Name="lblInfo" TextWrapping="Wrap" FontSize="12" LineHeight="18"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- footer -->
        <Border Grid.Row="2" Background="#FFF1F2F4" BorderBrush="#FFD3D6DA" BorderThickness="0,1,0,0" Padding="18,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource LightBtn}" Content="Отмена" Click="Cancel_Click"/>
                <Button x:Name="btnOk" Style="{StaticResource AmberBtn}" Content="Применить" Margin="8,0,0,0" Click="Ok_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
